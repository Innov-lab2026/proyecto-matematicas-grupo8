## AGREGAR EN LOS DOS PROYECTOS (FRONT Y BACK) EN VERCEL, EN "ENVIROMENT VARIABLES" ##

[1_ CONFIG DB]

[ESTÁ EN "HOME" SUPABASE]
SUPABASE_URL="https://[TU_PROYECTO].supabase.co"

[ESTÁ EN "SETTINGS" >> "API KEYS" USAR "PUBLISHABLE KEY" SUPABASE]
SUPABASE_ANON_KEY="[ANON_KEY]"

[COMPLETAR CON DATOS DESDE "TRANSACTION_POOLER" EN "CONNECT" (ICONO "ENCHUFE") >> PESTAÑA "DIRECT - CONNECTION STRING" SUPABASE]
DATABASE_URL="postgresql://postgres.[USUARIO]:[CONTRASEÑA]@aws-1-[ZONA].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

[COMPLETAR CON DATOS DESDE "SESSION_POOLER" EN "CONNECT" (ICONO "ENCHUFE") >> PESTAÑA "DIRECT - CONNECTION STRING" SUPABASE]
DIRECT_URL="postgresql://postgres.[USUARIO]:[CONTRASEÑA]@aws-1-[ZONA].pooler.supabase.com:5432/postgres"


[2_ CONFIG CLI]

[CON "CUENTA GOOGLE" IR A "https://aistudio.google.com/" >> "ACCEDER" >> "PROYECTOS" GENERAR PROYECTO (POR EJ: "MATE+") >> "GET API KEY" GENERAR NUEVA]
